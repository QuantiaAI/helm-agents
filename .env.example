# HelmAgents example environment variables.
# Copy to `.env` (gitignored) and fill in what you need.
# The engine resolves config as: DEFAULT_CONFIG → TRADINGAGENTS_* env → /settings overrides.

# ── Demo mode ────────────────────────────────────────────────────────────────
# Set to 1 to run the full 13-agent pipeline with a deterministic stub LLM
# (no paid key required). Great for demos, UI work, and local verification.
DEMO_LLM=1

# ── LLM provider ─────────────────────────────────────────────────────────────
# At least one provider key. See packages/llm/src/api-key-env.ts for the full
# list (OpenAI / Anthropic / Google / DeepSeek / 通义 / 智谱 / MiniMax /
# OpenRouter / Mistral / Moonshot / Groq / NVIDIA / xAI …). Ollama needs no key.
OPENAI_API_KEY=

# Optional provider/model overrides.
TRADINGAGENTS_LLM_PROVIDER=openai
TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.5
TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini

# ── Pipeline behavior ────────────────────────────────────────────────────────
TRADINGAGENTS_OUTPUT_LANGUAGE=English
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_ROUNDS=1
TRADINGAGENTS_TEMPERATURE=0.3
TRADINGAGENTS_CHECKPOINT_ENABLED=true

# ── API server (apps/api, NestJS) ────────────────────────────────────────────
# Port the standalone API listens on (defaults to 5171).
# API_PORT=5171
# Comma-separated CORS allow-list for the SPA origin(s). Unset reflects the
# request origin (fine for local dev); set explicitly in production.
# CORS_ORIGIN=http://localhost:5170
# Override the docs root served at GET /api/docs/* (defaults to the repo docs/).
# DOCS_ROOT=
# NDJSON run-stream heartbeat interval in ms (default 15000). Lower it if a
# reverse proxy in front closes idle connections sooner than 15s.
# STREAM_HEARTBEAT_MS=15000

# ── Authentication (multi-tenant) ───────────────────────────────────────────
# The API is multi-tenant: every /api/* route except health, docs, and
# /api/auth/* requires a Bearer access token (JWT). Sign-up is open
# (email + password). Refresh tokens are single-use, rotating, in an httpOnly
# cookie. See README "Authentication & multi-tenancy" for the full model.
# HMAC secret for access tokens. The dev default is insecure — set a strong
# value in production (the app warns if this is unset in prod).
# AUTH_JWT_SECRET=change-me-to-a-long-random-string
# Access-token lifetime in seconds (default 900 = 15 min).
# AUTH_ACCESS_TTL_SEC=900
# Refresh-token lifetime in seconds (default 2592000 = 30 days).
# AUTH_REFRESH_TTL_SEC=2592000
# Optional: seed a first account on boot (so you can log in without the UI).
# AUTH_BOOTSTRAP_EMAIL=admin@example.com
# AUTH_BOOTSTRAP_PASSWORD=

# ── Web SPA (apps/web, Vite) ─────────────────────────────────────────────────
# Build-time API base URL. Empty in dev (the Vite dev server proxies /api →
# API_PORT). Set this when building the SPA for a different origin than the API.
# VITE_API_BASE_URL=https://api.example.com
# Dev-only: override the dev-server proxy target (defaults to http://localhost:5171).
# VITE_API_PROXY=http://localhost:5171
